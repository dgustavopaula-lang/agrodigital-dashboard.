* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'Inter', system-ui, sans-serif;
  background: #f0f7f1;
  color: #1a2e1a;
  min-height: 100vh;
}

.login-bg {
  min-height: 100vh;
  background: linear-gradient(135deg, #1b5e20 0%, #2d7a3a 60%, #4caf50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.login-box {
  background: white;
  border-radius: 20px;
  padding: 48px 40px;
  width: 100%;
  max-width: 420px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
}

.login-logo {
  text-align: center;
  margin-bottom: 32px;
}

.login-logo h1 {
  font-size: 2rem;
  font-weight: 700;
  color: #1b5e20;
}

.login-logo p {
  color: #5a7a5a;
  margin-top: 4px;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.login-form label {
  font-size: 13px;
  font-weight: 600;
  color: #1a2e1a;
}

.login-form input {
  padding: 12px 16px;
  border: 1.5px solid #d0e8d0;
  border-radius: 10px;
  font-size: 15px;
  outline: none;
}

.login-form input:focus {
  border-color: #2d7a3a;
}

.btn-login {
  background: #2d7a3a;
  color: white;
  border: none;
  padding: 14px;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  margin-top: 8px;
}

.btn-login:hover {
  background: #1b5e20;
}

.login-hint {
  text-align: center;
  font-size: 12px;
  color: #5a7a5a;
}

.app-layout {
  display: flex;
  min-height: 100vh;
}

.sidebar {
  background: #1b5e20;
  color: white;
  width: 220px;
  display: flex;
  flex-direction: column;
}

.sidebar-header {
  padding: 24px 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.logo-texto {
  font-size: 20px;
  font-weight: 700;
  color: white;
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 16px 8px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border-radius: 10px;
  border: none;
  background: transparent;
  color: rgba(255, 255, 255, 0.7);
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  text-align: left;
}

.nav-item:hover {
  background: rgba(255, 255, 255, 0.1);
  color: white;
}

.nav-item.ativo {
  background: #4caf50;
  color: white;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.topbar {
  background: white;
  padding: 16px 32px;
  border-bottom: 1px solid #d0e8d0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.topbar-titulo {
  font-size: 20px;
  font-weight: 700;
  color: #1b5e20;
}

.topbar-sub {
  font-size: 13px;
  color: #5a7a5a;
  margin-top: 2px;
}

.topbar-usuario {
  font-size: 13px;
  color: #5a7a5a;
  background: #f0f7f1;
  padding: 8px 14px;
  border-radius: 20px;
}

.conteudo {
  padding: 28px 32px;
  flex: 1;
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}

.card {
  background: white;
  border-radius: 14px;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  border-left: 4px solid #d0e8d0;
}

.card-up {
  border-left-color: #4caf50;
}

.card-down {
  border-left-color: #e53935;
}

.card-stable {
  border-left-color: #f9a825;
}

.card-label {
  font-size: 12px;
  color: #5a7a5a;
  margin-bottom: 4px;
}

.card-value {
  font-size: 28px;
  font-weight: 700;
  color: #1b5e20;
}

.painel {
  background: white;
  border-radius: 14px;
  padding: 24px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  margin-bottom: 20px;
}

.painel h3 {
  font-size: 16px;
  font-weight: 600;
  color: #1b5e20;
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid #d0e8d0;
}

.tabela {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}

.tabela th {
  background: #f0f7f1;
  color: #1b5e20;
  padding: 12px 16px;
  text-align: left;
  font-weight: 600;
  border-bottom: 2px solid #d0e8d0;
}

.tabela td {
  padding: 12px 16px;
  border-bottom: 1px solid #d0e8d0;
}

.tabela tr:hover td {
  background: #f0f7f1;
}

.verde {
  color: #2d7a3a;
  font-weight: 600;
}

.vermelho {
  color: #e53935;
}

.alerta {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 16px;
  border-radius: 10px;
  margin-bottom: 10px;
  font-size: 14px;
}

.alerta-warning {
  background: #fff8e1;
  border-left: 3px solid #f9a825;
}

.alerta-info {
  background: #e3f2fd;
  border-left: 3px solid #1976d2;
}

.alerta-success {
  background: #e8f5e9;
  border-left: 3px solid #4caf50;
}

.barra-bg {
  background: #f0f7f1;
  border-radius: 99px;
  height: 8px;
  overflow: hidden;
  margin: 4px 0;
}

.barr a-fill {
  background: linear-gradient(90deg, #2d7a3a, #4caf50);
  height: 100%;
  border-radius: 99px;
}

.plantio-item {
  margin-bottom: 16px;
}

.plantio-header {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 4px;
}

.plantio-status {
  font-size: 12px;
  color: #5a7a5a;
}

.fazenda-info {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid #d0e8d0;
  font-size: 15px;
}

.info-row span {
  color: #5a7a5a;
}

.badge {
  background: #f0f7f1;
  color: #1b5e20;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
}

.painel-duplo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}cat >> src/styles.css << 'EOF'

/* FINANCEIRO */
.fin-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
.fin-cards{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
.fin-card{background:#1e293b;border-radius:12px;padding:20px;border-left:4px solid #666}
.fin-receita{border-color:#22c55e}.fin-despesa{border-color:#ef4444}
.fin-lucro{border-color:#3b82f6}.fin-prejuizo{border-color:#f97316}.fin-margem{border-color:#a855f7}
.fin-card-label{color:#94a3b8;font-size:13px;margin-bottom:8px}
.fin-card-valor{font-size:22px;font-weight:700;color:#f1f5f9}
.fin-filtros{display:flex;gap:16px;align-items:flex-end;margin-bottom:20px;flex-wrap:wrap}
.fin-filtro-grupo{display:flex;flex-direction:column;gap:6px}
.fin-filtro-grupo label{color:#94a3b8;font-size:13px}
.fin-filtro-grupo select{background:#1e293b;color:#f1f5f9;border:1px solid #334155;border-radius:8px;padding:8px 12px;font-size:14px}
.btn-limpar{background:#334155;color:#f1f5f9;border:none;border-radius:8px;padding:8px 16px;cursor:pointer}
.badge{padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600}
.badge-positivo{background:#14532d;color:#4ade80}.badge-negativo{background:#450a0a;color:#f87171}
.tabela tfoot .tabela-total{background:#1e3a2f;font-size:15px}
.sem-dados{text-align:center;color:#94a3b8;padding:40px}

/* === DASHBOARD MELHORADO === */
.dash-grid{display:grid;grid-template-columns:1fr 280px;gap:20px;margin-bottom:20px}
.dash-card-grande{background:#1e293b;border-radius:12px;padding:24px}
.dash-col-direita{display:flex;flex-direction:column;gap:12px}
.dash-titulo{color:#f1f5f9;font-size:15px;margin-bottom:16px}
.grafico-barras{display:flex;align-items:flex-end;gap:8px;height:160px;padding-bottom:8px}
.barra-grupo{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1}
.barras-wrap{display:flex;gap:3px;align-items:flex-end}
.barra-receita{width:14px;background:#22c55e;border-radius:4px 4px 0 0;min-height:4px;transition:height .3s}
.barra-despesa{width:14px;background:#ef4444;border-radius:4px 4px 0 0;min-height:4px;transition:height .3s}
.barra-label{font-size:10px;color:#64748b}
.grafico-legenda{display:flex;gap:16px;margin-top:12px}
.leg-receita{color:#22c55e;font-size:13px}
.leg-despesa{color:#ef4444;font-size:13px}
.dash-kpi-card{display:flex;align-items:center;gap:12px;background:#1e293b;border-radius:10px;padding:14px;border-left:4px solid #666}
.kpi-verde{border-color:#22c55e}.kpi-azul{border-color:#3b82f6}.kpi-vermelho{border-color:#ef4444}.kpi-roxo{border-color:#a855f7}
.kpi-icon{font-size:22px}
.kpi-label{color:#94a3b8;font-size:12px;margin:0 0 2px}
.kpi-valor{color:#f1f5f9;font-size:18px}
.dash-grid-bottom{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.dash-card-medio{background:#1e293b;border-radius:12px;padding:20px}
.plantio-status-grid{display:flex;flex-direction:column;gap:12px}
.plantio-status-item{display:flex;flex-direction:column;gap:6px}
.ps-topo{display:flex;align-items:center;gap:8px}
.ps-label{color:#cbd5e1;font-size:14px;flex:1}
.ps-qt{color:#f1f5f9;font-size:14px}
.ps-barra-bg{background:#0f172a;border-radius:4px;height:6px}
.ps-barra-fill{height:6px;border-radius:4px;transition:width .5s}
.culturas-lista{display:flex;flex-direction:column;gap:10px}
.cultura-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #1e293b}
.cultura-nome{color:#cbd5e1;font-size:14px}
.cultura-area{color:#22c55e;font-size:13px;font-weight:600}
.alertas-lista{display:flex;flex-direction:column;gap:10px}
.alerta-mini{display:flex;align-items:flex-start;gap:10px;padding:10px;border-radius:8px;background:#0f172a}
.alerta-mini-dot{width:8px;height:8px;border-radius:50%;margin-top:4px;flex-shrink:0}
.alerta-warning .alerta-mini-dot{background:#f59e0b}
.alerta-info .alerta-mini-dot{background:#3b82f6}
.alerta-success .alerta-mini-dot{background:#22c55e}
.alerta-mini-msg{color:#cbd5e1;font-size:13px;margin:0}
